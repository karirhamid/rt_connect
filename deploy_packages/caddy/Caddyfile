# ============================================================================
# Caddy reverse proxy — terminates HTTPS for the LAN-only deployment.
#
# Strategy: ON-DEMAND TLS with the local internal CA.
#   • On every first connection to https://<anything>, Caddy generates a
#     cert for that hostname/IP, signed by its local CA.
#   • The CA itself is created once and stored in the caddy_data volume.
#   • The "ask" endpoint is the backend's /health route — Caddy queries it
#     to confirm the host is allowed (always returns 200, so any host on
#     this LAN is accepted).
# ============================================================================

{
    auto_https disable_redirects
    admin off

    # Allow on-demand cert generation for any hostname/IP. Caddy hits the
    # `ask` URL to verify it's permitted; backend /health always returns 200.
    on_demand_tls {
        ask http://backend:8000/health
    }
}

# ── HTTPS catch-all on :443 ─────────────────────────────────────────────────
# Matches any host: 192.168.1.50, 172.16.1.10, https://server.local, etc.
:443 {
    tls {
        on_demand
        issuer internal
    }

    reverse_proxy frontend:80

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Frame-Options            "SAMEORIGIN"
        X-Content-Type-Options     "nosniff"
        Referrer-Policy            "strict-origin-when-cross-origin"
        -Server
    }

    encode gzip zstd
}

# ── HTTP redirect to HTTPS ──────────────────────────────────────────────────
:80 {
    redir https://{host}{uri} permanent
}
