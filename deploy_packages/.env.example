# ============================================================================
# RT Connect — Deployment configuration
# Copy this file to ".env" and edit the values for your environment.
# ============================================================================

# ── Where the app is reachable ───────────────────────────────────────────────
# The IP or hostname of THIS server on the client's local network.
# Used to build the ALLOWED_ORIGINS list for CORS.
SERVER_IP=192.168.1.50

# Public HTTP port (Caddy listens here and redirects to HTTPS).
# Default 80. Use 8080 if 80 is busy on this server.
HTTP_PORT=80

# Public HTTPS port (Caddy serves the app here with an auto self-signed cert).
# Default 443. Use 8443 if 443 is busy.
HTTPS_PORT=443

# Comma-separated list of allowed origins for CORS.
# Include https://SERVER_IP (and the http variant if you'll allow that too).
ALLOWED_ORIGINS=https://192.168.1.50,http://192.168.1.50,http://localhost

# ── Database credentials ─────────────────────────────────────────────────────
DB_NAME=rtzkconnect_db
DB_USER=rtconnect
DB_PASSWORD=changeme_strong_password

# ── Application version (used as Docker image tag) ───────────────────────────
APP_VERSION=2.1.0

# ── Server timezone (drives schedule timing and report dates) ────────────────
TZ=Africa/Casablanca

# ── ZKTeco device connection defaults ───────────────────────────────────────
# Devices are added and edited from the web admin (Devices page).
# These are only fallback values used if a device record is missing them.
DEVICE_TIMEOUT=30
DEVICE_PASSWORD=0

# ── Backup credential encryption ─────────────────────────────────────────────
# Encrypts the SMB backup password stored in the database. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep it stable — changing it makes previously saved SMB passwords unreadable.
BACKUP_ENC_KEY=
